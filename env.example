# ═══ AssistantIA Domotique — Configuration ═══
# Copier ce fichier en .env et remplir les valeurs.
# Le wizard install.sh peut le générer interactivement pour vous.

# ─── REQUIS ───

# Bot Telegram (créé via @BotFather → /newbot)
TELEGRAM_TOKEN=

# Home Assistant
HA_URL=http://192.168.1.XX:8123
HA_TOKEN=

# Anthropic API Key (console.anthropic.com)
ANTHROPIC_API_KEY=

# ─── OPTIONNEL ───

# Budget mensuel API en USD (alerte à 50/80/100%)
ANTHROPIC_MONTHLY_BUDGET_USD=10

# Méthode de sécurité pour le code à 6 chiffres au démarrage
# Valeurs possibles : free_mobile | ha_notify | email
SMS_METHOD=ha_notify

# SMS Free Mobile (uniquement si SMS_METHOD=free_mobile)
FREE_MOBILE_USER=
FREE_MOBILE_PASS=

# Email SMTP (uniquement si SMS_METHOD=email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_DEST=

# ─── AVANCÉ : Mode bêta-testeur (opt-in) ───
# Active le deploy_server pour recevoir des patches à distance.
# NE PAS ACTIVER sauf si vous voulez recevoir les correctifs automatiques.
# Voir docs/BETA_CHANNEL.md pour les implications de sécurité.
ENABLE_DEPLOY_SERVER=false
